<mvc:View controllerName="mic.pur.fioriapp01.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:core="sap.ui.core">
    <Page id="page2" title="{i18n>titleView1}">
        <content>
        <ObjectHeader title="{CARRID}" number="{CARRNAME}" >
        </ObjectHeader>
        <IconTabBar >
		<items>
			<IconTabFilter icon="sap-icon://warning" text="More Info">
				<core:Fragment fragmentName="mic.pur.fioriapp01.fragments.InfoForm" type="XML"></core:Fragment>
			</IconTabFilter>
			<IconTabFilter
				icon="sap-icon://notes"
				text="Other"
				>
				<Text text="Others go here ..." />
			</IconTabFilter>
			
		</items>
	    </IconTabBar>
        </content>
    </Page>
</mvc:View>
